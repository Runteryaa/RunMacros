<%- include('header') %>
<h1>Dashboard</h1>
<canvas id="calorieChart" width="400" height="200"></canvas>
<script>
const ctx = document.getElementById('calorieChart').getContext('2d');
const data = {
    labels: <%- JSON.stringify(Object.keys(totals)) %>,
    datasets: [{
        label: 'Calories',
        data: <%- JSON.stringify(Object.values(totals)) %>,
        backgroundColor: 'rgba(75,192,192,0.2)',
        borderColor: 'rgba(75,192,192,1)',
        borderWidth: 1
    }]
};
new Chart(ctx, {
    type: 'bar',
    data: data,
    options: { scales: { y: { beginAtZero: true } } }
});
</script>
<%- include('footer') %>
