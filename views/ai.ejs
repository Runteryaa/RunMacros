<%- include('header') %>
<h1>AI Recipe Generator</h1>
<form action="/ai/generate" method="POST">
    <textarea name="prompt" rows="4" cols="50" placeholder="Describe your preferences"></textarea>
    <button type="submit">Generate</button>
</form>
<% if (recipe) { %>
    <h2>Generated Recipe</h2>
    <pre><%= recipe %></pre>
    <form action="/ai/save" method="POST">
        <input type="hidden" name="recipe" value="<%- recipe.replace(/"/g, '&quot;') %>">
        <button type="submit">Save to Recipes</button>
    </form>
<% } %>
<%- include('footer') %>
